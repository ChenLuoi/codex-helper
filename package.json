{
  "name": "codex-ops",
  "version": "0.1.9",
  "description": "A local operations CLI for Codex auth, usage, and limit workflows.",
  "homepage": "https://github.com/ChenLuoi/codex-ops#readme",
  "bugs": {
    "url": "https://github.com/ChenLuoi/codex-ops/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChenLuoi/codex-ops.git"
  },
  "type": "module",
  "bin": {
    "codex-ops": "bin/codex-ops.js"
  },
  "files": [
    "bin/**/*.js",
    "bin/*/codex-ops",
    "bin/*/codex-ops.exe",
    "npm/**/bin/codex-ops",
    "npm/**/bin/codex-ops.exe",
    "README.md"
  ],
  "scripts": {
    "build": "cargo build --release",
    "lint": "cargo clippy --all-targets --all-features -- -D warnings",
    "test": "cargo test",
    "release:check": "node scripts/check-release.mjs",
    "release:dry-run": "node scripts/verify-release-layout.mjs",
    "smoke:rust-cli": "cargo test --tests",
    "smoke:npm-shim": "node scripts/smoke-npm-shim.mjs",
    "bench:rust": "cargo build --release && cargo run --release --bin codex-ops-bench -- --fixture test/fixtures/rust-run --runs 1",
    "prepublishOnly": "npm run release:check && npm run lint && npm run test && npm run build && npm run smoke:rust-cli && npm run smoke:npm-shim"
  },
  "keywords": [
    "codex",
    "cli",
    "ops",
    "auth",
    "usage"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.12.0"
  },
  "optionalDependencies": {
    "@codexops/linux-x64-gnu": "0.1.9",
    "@codexops/linux-arm64-gnu": "0.1.9",
    "@codexops/linux-x64-musl": "0.1.9",
    "@codexops/linux-arm64-musl": "0.1.9",
    "@codexops/darwin-x64": "0.1.9",
    "@codexops/darwin-arm64": "0.1.9",
    "@codexops/win32-x64-msvc": "0.1.9"
  }
}
